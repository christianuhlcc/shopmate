GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=change-me-in-production-minimum-32-characters-long
# Reusable NEW_GROUP invite code for bootstrapping a fresh environment, where no
# group exists yet and invite codes can only be issued by existing members.
# Empty (the default) disables it. UNSET THIS once the first group exists — while
# set it is a standing credential that lets any signed-in user create a group.
BOOTSTRAP_INVITE_CODE=
# Only read by deploy/aws/set-secrets.sh (prod observability) — not used locally.
# Create an Ingesting-permission token in Dash0 under Settings -> Auth Tokens.
DASH0_AUTH_TOKEN=
