{
  "apiVersion": "openslo/v1",
  "kind": "SLO",
  "metadata": {
    "name": "shopmate-backend-error-rate",
    "labels": {
      "service": "shopmate-backend",
      "namespace": "shopmate",
      "team": "shopmate"
    }
  },
  "spec": {
    "budgetingMethod": "Occurrences",
    "description": "99.9% of shopmate-backend server requests complete without an ERROR span status over a rolling 28-day window.",
    "indicator": {
      "spec": {
        "ratioMetric": {
          "counter": true,
          "good": {
            "metricSource": {
              "type": "Prometheus",
              "spec": {
                "query": "{otel_metric_name=\"dash0.spans\", service_name=\"shopmate-backend\", otel_span_kind=\"SERVER\", otel_span_status_code!=\"ERROR\"}"
              }
            }
          },
          "total": {
            "metricSource": {
              "type": "Prometheus",
              "spec": {
                "query": "{otel_metric_name=\"dash0.spans\", service_name=\"shopmate-backend\", otel_span_kind=\"SERVER\"}"
              }
            }
          }
        }
      }
    },
    "timeWindow": [{ "duration": "28d", "isRolling": true }],
    "objectives": [{
      "displayName": "shopmate-backend: 99.9% error rate",
      "target": 0.999
    }]
  }
}
